# ── Copy this file to .env and fill in your values ──────────────────────────

# Supabase (from https://supabase.com → your project → Settings → API)
SUPABASE_URL=https://zgfbtdsxisyidcrsahky.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# JWT Secret — generate a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string

# Stripe Keys (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price IDs (from https://dashboard.stripe.com/products)
# Create two products in Stripe: "Investor Plan" ($25/mo) and "Portfolio Plan" ($80/mo)
# Then paste the Price IDs (starting with price_) below
STRIPE_PRICE_INVESTOR=price_YOUR_INVESTOR_PRICE_ID
STRIPE_PRICE_PORTFOLIO=price_YOUR_PORTFOLIO_PRICE_ID

# App URL — change to your deployed URL when going live
APP_URL=http://localhost:3000

# Admin key — used to authorise manual plan overrides via API
ADMIN_KEY=change_this_to_a_long_random_string

# Server port (optional, defaults to 3000)
PORT=3000
